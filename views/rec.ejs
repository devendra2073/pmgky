<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="content-type" content="text/html; charset=utf-8" />
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title></title>
  <style>
    .receipt-container {
        width: 550px; /* चौड़ाई बढ़ाई गई */
        margin: 30px auto;
        padding: 40px;
        background: #fff;
        border: 2px solid #eee;
        border-radius: 8px;
        font-family: 'Hind', sans-serif;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        position: relative;
    }

    /* जानकारी को दो कॉलम में दिखाने के लिए */
    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 10px;
    }

    .receipt-header {
        text-align: center;
        border-bottom: 3px solid #ff9933; /* केसरिया बॉर्डर */
        padding-bottom: 20px;
        margin-bottom: 25px;
    }

    .receipt-logo { width: 60px; margin-bottom: 10px; }
    
    .detail-item {
        display: flex;
        justify-content: space-between;
        padding: 8px 0;
        border-bottom: 1px dashed #eee;
    }

    .detail-item label { color: #666; font-size: 14px; }
    .detail-item span { font-weight: bold; color: #333; }

    .receipt-footer {
        margin-top: 40px;
        text-align: center;
        border-top: 1px solid #eee;
        padding-top: 20px;
    }

    #barcode {
        margin-top: 10px;
        max-width: 100%;
    }

    .status-stamp {
        position: absolute;
        top: 150px;
        right: 20px;
        border: 4px solid #128807;
        color: #128807;
        padding: 10px 20px;
        font-size: 30px;
        font-weight: 900;
        transform: rotate(-15deg);
        opacity: 0.15;
        border-radius: 10px;
    }
</style>

  </head>
  <body>
  
<button onclick="print()">Print</button>
<div id="receipt" class="receipt-container">
    <div class="receipt-header">
        <img src="/media/emblem.png" alt="Emblem" class="receipt-logo">
        <h2>भारत सरकार</h2>
        <h3>प्रधानमंत्री गरीब कल्याण योजना (PMGKY)</h3>
        <p>पंजीकरण पावती पत्र | 2026-27</p>
    </div>

    <div class="receipt-body">
        <div class="status-stamp">सत्यापित</div>
        
        <div class="info-grid">
            <div class="info-row">
                <span>संदर्भ संख्या (Ref No):</span>
                <strong id="ref-no"><%=trac%></strong> </div>
            <div class="info-row">
                <span>दिनांक (Date):</span>
                <strong id="date-now"></strong>
            </div>
        </div>

        <hr>

        <div class="details-section">
            <div class="detail-item">
                <label>लाभार्थी का नाम:</label>
                <span id="user-name"><%=name%></span>
            </div>
            <div class="detail-item">
                <label>योजना का लाभ:</label>
                <span>₹1000 / माह (Direct Benefit Transfer)</span>
            </div>
            <div class="detail-item">
                <label>सत्यापन स्थिति:</label>
                <span style="color: #128807;">सफल (Successful)</span>
            </div>
        </div>
    </div>

    <div class="receipt-footer">
        <svg id="barcode"></svg> 
        <p>यह पोर्टल भ्रष्टाचार मुक्त और पारदर्शी सेवा सुनिश्चित करता है।</p>
        <p class="copyright">© 2026 National Informatics Centre (NIC)</p>
    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        // 1. आज की तारीख
        const today = new Date();
        document.getElementById('date-now').innerText = today.toLocaleDateString('hi-IN');

        // 2. रैंडम संदर्भ संख्या (Ref No)
        const randomRef = "PMGKY<%=trac%>"
        document.getElementById('ref-no').innerText = randomRef;

        // 3. बारकोड जनरेट करना
        JsBarcode("#barcode", randomRef, {
            format: "CODE128",
            lineColor: "#000",
            width: 2,
            height: 50,
            displayValue: true, // बारकोड के नीचे नंबर दिखाएगा
            fontSize: 14,
            font: "monospace"
        });
    });
</script>

  </body>
</html>
